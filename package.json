{
  "name": "server",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "rimraf dist && npx tsc --build --verbose",
    "build:prod": "NODE_ENV=production rimraf dist && npx tsc --project tsconfig.prod.json && npm run minify",
    "minify": "find dist -name '*.js' -exec terser {} --compress --mangle --output {} \\;",
    "start": "npm run build && npm run serve",
    "start:prod": "npm run build:prod && npm run serve:prod",
    "serve": "node dist/index.js",
    "serve:prod": "NODE_ENV=production node dist/index.js",
    "dev": "npm run build && concurrently \"npx tsc -w\" \"nodemon --exec ts-node src/index.ts\"",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "seed": "ts-node src/scripts/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.740.0",
    "@aws-sdk/lib-storage": "^3.740.0",
    "@terraformer/wkt": "^2.2.1",
    "@types/json2csv": "^5.0.7",
    "@types/node-cron": "^3.0.11",
    "@types/node-fetch": "^2.6.11",
    "@types/pdfkit": "^0.17.2",
    "@types/pg": "^8.15.5",
    "@types/qrcode": "^1.5.5",
    "axios": "^1.11.0",
    "better-auth": "^1.3.8",
    "body-parser": "^1.20.3",
    "cloudinary": "^2.7.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.44.5",
    "express": "^4.21.2",
    "flutterwave-node-v3": "^1.1.10",
    "helmet": "^8.0.0",
    "json2csv": "^6.0.0-alpha.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "paystack": "^2.0.1",
    "pdfkit": "^0.17.1",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "resend": "^6.0.1",
    "tslib": "^2.8.1",
    "uuid": "^11.0.5",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.0",
    "@types/terraformer__wkt": "^2.0.3",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "rimraf": "^6.0.1",
    "shx": "^0.3.4",
    "terser": "^5.36.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
